#!/usr/bin/env python3
"""
cd-real-cost: compute the actual cost of a claude -p call routed through LiteLLM.

Claude Code reports Anthropic rates regardless of actual backend. When
routing through LiteLLM (via ANTHROPIC_BASE_URL) to cheaper models, the
reported cost is wrong by 6-50x.

Usage:
  echo '{"usage": {...}, "modelUsage": {...}}' | cd-real-cost [--model NAME]
  cd-real-cost --model gemini-3-flash --in 39532 --out 5

Env:
  LITELLM_URL       Default: http://localhost:4000
  LITELLM_KEY       Default: reads from ~/.claude-daemon/config.json

Output: JSON with real_cost_usd, reported_cost_usd, savings_factor.
"""

import json
import os
import sys
from pathlib import Path
from urllib.request import Request, urlopen
from urllib.error import URLError

LITELLM_URL = os.environ.get("LITELLM_URL", "http://localhost:4000")
LITELLM_KEY = os.environ.get("LITELLM_KEY", "")


def get_key_from_config():
    """Read LiteLLM key from daemon config if not in env."""
    if LITELLM_KEY:
        return LITELLM_KEY
    config_path = Path.home() / ".claude-daemon" / "config.json"
    if config_path.exists():
        try:
            cfg = json.loads(config_path.read_text())
            return cfg.get("litellm", {}).get("key", "")
        except (json.JSONDecodeError, KeyError):
            pass
    return ""


_model_cache = None


def get_model_rates(model_name):
    """Fetch current rates for a model from LiteLLM /model/info."""
    global _model_cache
    if _model_cache is None:
        key = get_key_from_config()
        if not key:
            return None
        try:
            req = Request(
                f"{LITELLM_URL}/model/info",
                headers={"Authorization": f"Bearer {key}"},
            )
            with urlopen(req, timeout=5) as resp:
                data = json.loads(resp.read())
            _model_cache = {}
            for m in data.get("data", []):
                name = m.get("model_name")
                info = m.get("model_info", {})
                in_cost = info.get("input_cost_per_token", 0) or 0
                out_cost = info.get("output_cost_per_token", 0) or 0
                # Take the first (cheapest) backend if multiple
                if name not in _model_cache:
                    _model_cache[name] = {"input": in_cost, "output": out_cost}
        except (URLError, json.JSONDecodeError, KeyError):
            return None

    return _model_cache.get(model_name)


def compute_real_cost(model, input_tokens, output_tokens):
    """Return (real_cost, rates_found_bool)."""
    rates = get_model_rates(model)
    if not rates:
        return None, False
    real_cost = (input_tokens * rates["input"]) + (output_tokens * rates["output"])
    return real_cost, True


def main():
    args = sys.argv[1:]
    model = None
    input_tokens = None
    output_tokens = None
    reported_cost = None

    # Parse flags
    i = 0
    while i < len(args):
        if args[i] == "--model" and i + 1 < len(args):
            model = args[i + 1]
            i += 2
        elif args[i] == "--in" and i + 1 < len(args):
            input_tokens = int(args[i + 1])
            i += 2
        elif args[i] == "--out" and i + 1 < len(args):
            output_tokens = int(args[i + 1])
            i += 2
        else:
            i += 1

    # If not provided via flags, read from stdin (claude -p JSON output)
    if input_tokens is None or output_tokens is None:
        try:
            data = json.load(sys.stdin)
            usage = data.get("usage", {})
            input_tokens = usage.get("input_tokens", 0) + usage.get("cache_creation_input_tokens", 0)
            output_tokens = usage.get("output_tokens", 0)
            reported_cost = data.get("total_cost_usd", 0)
            # Extract model name from modelUsage dict
            if not model:
                model_usage = data.get("modelUsage", {})
                if model_usage:
                    model = list(model_usage.keys())[0]
        except (json.JSONDecodeError, KeyError):
            print(json.dumps({"error": "could not parse stdin as JSON"}))
            sys.exit(1)

    if not model:
        print(json.dumps({"error": "model not specified (use --model or pipe claude -p output)"}))
        sys.exit(1)

    real_cost, found = compute_real_cost(model, input_tokens, output_tokens)

    result = {
        "model": model,
        "input_tokens": input_tokens,
        "output_tokens": output_tokens,
        "rates_found": found,
    }

    if found:
        result["real_cost_usd"] = round(real_cost, 6)
        if reported_cost:
            result["reported_cost_usd"] = reported_cost
            if real_cost > 0:
                result["savings_factor"] = round(reported_cost / real_cost, 2)

    print(json.dumps(result, indent=2))


if __name__ == "__main__":
    main()
