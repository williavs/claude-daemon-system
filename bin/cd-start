#!/usr/bin/env bash
# cd-start: Start the daemon in background
set -euo pipefail

source "$(dirname "$0")/../lib/config.sh"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Check if already running
if [ -f "$DAEMON_HOME/state/daemon.pid" ]; then
    pid=$(cat "$DAEMON_HOME/state/daemon.pid")
    if kill -0 "$pid" 2>/dev/null; then
        echo "Daemon already running (PID $pid)"
        exit 1
    fi
fi

echo "Starting Claude Daemon..."
nohup "$SCRIPT_DIR/cd-engine" > "$DAEMON_HOME/logs/daemon.log" 2>&1 &
echo "Daemon started (PID $!)"
echo "  Logs: tail -f $DAEMON_HOME/logs/daemon.log"
echo "  Status: cd-status"
echo "  Add tasks: cd-add \"task description\""
